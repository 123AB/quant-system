# ======================== Quant System ========================
# Copy to .env and modify as needed

# ─── PostgreSQL (TimescaleDB) ────
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_2026
PG_PORT=5432

# ─── Redis ───────────────────────
REDIS_PORT=6379

# ─── JWT ─────────────────────────
JWT_SECRET=change_this_in_production

# ─── LLM Provider ───────────────
# Options: openai, anthropic, dashscope (Alibaba Qwen)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=

# ─── Signal Agent ────────────────
SIGNAL_INTERVAL_MINUTES=30
